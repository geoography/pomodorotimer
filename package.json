{
  "name": "pomodorotimer",
  "version": "1.0.0",
  "description": "Proyek: Alarm Belajar Teknik Pomodoro | Nama Kelompok: Suara Minoritas | Anggota: Naufal Rasyiq Dziqri Simanjuntak (251401002) -> Frontend | Naila Azzahra (251401026) -> Frontend | Geofrey Melvern (251401059) -> Backend | Frans Eikel Martogi (251401134) -> Backend",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geoography/PomodoroTimer.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/geoography/PomodoroTimer/issues"
  },
  "homepage": "https://github.com/geoography/PomodoroTimer#readme",
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.suaraminoritas.pomodorotimer",
    "productName": "PomodoroTimer",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/logoPomodoroTimer.png"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    }
  }
}